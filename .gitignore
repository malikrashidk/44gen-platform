# Dependencies
node_modules/
*/node_modules/

# Environment files (never push these)
.env
*/.env
**/.env

# Build outputs
dist/
*/dist/
build/

# Compiled frontend bundle (app/ contains the built output)
# The hashed asset filenames (app/assets/index-XXXXXX.js) change every build.
# Committing them causes stale bundles. Build via: cd frontend && npm run build && cp -r dist/* ../app/
app/assets/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# PM2
.pm2/

# User generated apps
users/

