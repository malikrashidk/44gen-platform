# ============================================================
# 44gen Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=4000
# Exact origin of your frontend (no trailing slash)
ALLOWED_ORIGIN=https://44gen.com

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# Service role key — bypasses RLS. Keep secret, backend only.
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# Primary model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# Comma-separated fallback models if primary is unavailable
GEMINI_FALLBACK_MODELS=gemini-1.5-flash,gemini-1.5-pro

# ── Cloudflare ───────────────────────────────────────────────
CF_ZONE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CF_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Pexels (stock photos — paid plan feature) ────────────────
PEXELS_API_KEY=563492ad...

# ── GitHub OAuth (export feature) ───────────────────────────
GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must match exactly what's set in your GitHub OAuth App settings
GITHUB_REDIRECT_URI=https://44gen.com/api/github/connect/callback

# ── GitHub Security (generate with: openssl rand -base64 32) ─
# Signs OAuth state parameter — prevents CSRF on OAuth callback
GITHUB_OAUTH_STATE_SECRET=
# AES-256-GCM key for encrypting stored GitHub access tokens
GITHUB_TOKEN_ENCRYPTION_KEY=
