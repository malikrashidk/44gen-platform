{
	email support@44gen.com
	on_demand_tls {
		ask http://localhost:4000/internal/domain-check
	}
}

44gen.com {
	tls /etc/letsencrypt/live/44gen.com/fullchain.pem /etc/letsencrypt/live/44gen.com/privkey.pem
	reverse_proxy localhost:8080 {
		header_up X-Forwarded-Proto https
		header_up X-Real-IP {remote_host}
	}
}

www.44gen.com {
	tls /etc/letsencrypt/live/44gen.com/fullchain.pem /etc/letsencrypt/live/44gen.com/privkey.pem
	redir https://44gen.com{uri} 301
}

*.44gen.com {
	tls /etc/letsencrypt/live/44gen.com/fullchain.pem /etc/letsencrypt/live/44gen.com/privkey.pem
	reverse_proxy localhost:8080 {
		header_up X-Forwarded-Proto https
		header_up X-Real-IP {remote_host}
	}
}

