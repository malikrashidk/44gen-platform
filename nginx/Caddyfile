:443 {
	tls {
		on_demand
	}
	reverse_proxy localhost:4000 {
		header_up X-Forwarded-Proto https
		header_up X-Real-IP {remote_host}
		header_up Host {host}
	}
}

:80 {
	handle /.well-known/acme-challenge/* {
		reverse_proxy localhost:4000
	}
	handle {
		redir https://{host}{uri} 301
	}
}